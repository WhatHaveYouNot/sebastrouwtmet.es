---
import WeddingLayout from '../layouts/WeddingLayout.astro';
import HeroHeader from '../components/HeroHeader.astro';
import PersonalLetter from '../components/PersonalLetter.astro';
import SectionDivider from '../components/SectionDivider.astro';
import LocationBlock from '../components/LocationBlock.astro';
import ProgramTimeline from '../components/ProgramTimeline.astro';
import CeremonyMaster from '../components/CeremonyMaster.astro';
import RSVPButton from '../components/RSVPButton.astro';
import FAQ from '../components/FAQ.astro';
import Acts from '../components/Acts.astro';
import GiftTip from '../components/GiftTip.astro';
import StickyRSVP from '../components/StickyRSVP.astro';
import data from '../data/wedding-data.json';

const d = data.weekend;

const DUTCH_MONTHS: Record<string, number> = {
  januari:0,februari:1,maart:2,april:3,mei:4,juni:5,
  juli:6,augustus:7,september:8,oktober:9,november:10,december:11,
};
function countdownFrom(program: typeof d.program): string {
  const day = program.days[0];
  const parts = day.label.trim().split(' ');
  const month = DUTCH_MONTHS[parts[2].toLowerCase()] ?? 9;
  const rawTime = day.items[0].time.split(' - ')[0];
  const [h, m] = rawTime.split(':').map(Number);
  return new Date(2026, month, parseInt(parts[1], 10), h, m).toISOString();
}
const countdownTarget = countdownFrom(d.program);
---

<WeddingLayout title="Sebastiaan & Esmeralda — Weekendgasten" variant="weekend">
  <HeroHeader {...d.header} countdownTarget={countdownTarget} />
  <PersonalLetter text={d.letter.text} />
  <SectionDivider />
  <LocationBlock {...d.location} />
  <SectionDivider />
  <ProgramTimeline days={d.program.days} />
  <SectionDivider />
  <CeremonyMaster {...d.mc} />
  <SectionDivider />
  <RSVPButton {...d.rsvp} />
  <SectionDivider />
  <FAQ items={d.faq.items} />
  <SectionDivider />
  <Acts {...d.acts} />
  <SectionDivider />
  <GiftTip {...d.gift} />
  <StickyRSVP {...d.rsvp} />
</WeddingLayout>
