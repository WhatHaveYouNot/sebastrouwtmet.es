---
interface Props {
  venue_name: string;
  address: string;
  region: string;
  arrival_label: string;
  arrival_note: string;
  maps_query: string;
}

const { venue_name, address, region, arrival_note, maps_query } = Astro.props;
const mapsUrl = `https://maps.google.com/maps?q=${maps_query}&output=embed&hl=nl&t=h`;

const commaIdx = address.indexOf(', ');
const street = commaIdx >= 0 ? address.slice(0, commaIdx) : address;
const cityPostal = commaIdx >= 0 ? address.slice(commaIdx + 2) : '';
---

<section id="locatie" class="section-padding bg-wedding-bg">
  <div class="content-width">
    <div class="grid md:grid-cols-2 gap-10 md:gap-16 items-start">
      <!-- Details -->
      <div>
        <p data-reveal class="text-[13px] uppercase tracking-[0.3em] text-wedding-accent font-body mb-4">
          Locatie
        </p>

        <!-- Address card -->
        <div data-reveal data-reveal-delay="1" class="mb-8">
          <div class="flex items-start gap-3">
            <span class="text-lg flex-shrink-0 mt-0.5" aria-hidden="true">📍</span>
            <div>
              <p
                class="font-display text-wedding-text text-2xl mb-1 leading-tight"
                style="font-weight: 700; letter-spacing: -0.01em;"
              >{venue_name}</p>
              <p class="text-wedding-muted mb-0.5" style="font-weight: 500;">{street}</p>
              <p class="text-wedding-muted mb-2" style="font-weight: 400;">{cityPostal}</p>
              <p class="text-wedding-muted" style="font-weight: 300; font-size: 0.75rem; letter-spacing: 0.1em; text-transform: uppercase; opacity: 0.6;">{region}</p>
            </div>
          </div>
        </div>

        <p
          data-reveal
          data-reveal-delay="3"
          class="text-wedding-muted text-sm leading-relaxed"
          style="font-weight: 400;"
        >
          {arrival_note}
        </p>
      </div>

      <!-- Map -->
      <div
        data-reveal
        data-reveal-delay="2"
        class="rounded-2xl overflow-hidden"
        style="aspect-ratio: 1 / 1; box-shadow: 0 12px 48px rgba(0,0,0,0.4); border: 1px solid rgba(255,255,255,0.15);"
      >
        <iframe
          src={mapsUrl}
          width="100%"
          height="100%"
          style="border: 0; display: block;"
          allowfullscreen
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title={`Kaart van ${venue_name}`}
        ></iframe>
      </div>
    </div>
  </div>
</section>
