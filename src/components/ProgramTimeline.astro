---
interface ProgramItem {
  time: string;
  title: string;
  detail: string;
}

interface Day {
  label: string;
  items: ProgramItem[];
}

interface Props {
  days: Day[];
}

const { days } = Astro.props;
const isMultiDay = days.length > 1;
---

{
  isMultiDay ? (
    /* ── Horizontal scroll layout (desktop) / vertical (mobile) ── */
    <section data-h-scroll class="relative bg-wedding-bg">
      {/* Mobile: vertical timeline */}
      <div class="md:hidden section-padding">
        <div class="content-width">
          <p class="text-xs uppercase tracking-[0.3em] text-wedding-accent font-body mb-4">
            Programma
          </p>
          <h2
            data-letter-reveal
            class="font-display text-4xl text-wedding-text mb-14"
            style="font-weight: 600;"
          >
            Het programma
          </h2>
          {days.map((day) => (
            <div class="mb-14 last:mb-0">
              <h3 class="text-lg text-wedding-gold mb-6" style="font-weight: 500; letter-spacing: 0.05em;">
                {day.label}
              </h3>
              <div class="relative pl-6">
                <div class="absolute left-0 top-2 bottom-2 w-px bg-wedding-divider" />
                <div class="space-y-7">
                  {day.items.map((item) => (
                    <div class="relative">
                      <div class="absolute -left-[1.625rem] top-1.5 w-2.5 h-2.5 rounded-full bg-wedding-accent ring-2 ring-[#8B0020]" />
                      <div class="flex items-baseline gap-5">
                        {item.time && (
                          <span class="text-wedding-accent text-sm font-body tabular-nums shrink-0 min-w-[3rem]" style="font-weight: 400;">
                            {item.time}
                          </span>
                        )}
                        <div>
                          <span class="text-wedding-text font-body" style="font-weight: 500;">{item.title}</span>
                          {item.detail && (
                            <p class="text-wedding-muted text-sm mt-1 leading-relaxed" style="font-weight: 300;">
                              {item.detail}
                            </p>
                          )}
                        </div>
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      {/* Desktop: sticky horizontal scroll */}
      <div class="hidden md:block sticky top-0 h-screen overflow-hidden">
        {/* Header */}
        <div
          class="absolute top-0 left-0 right-0 pt-16 pb-8 z-10 text-center"
          style="background: linear-gradient(to bottom, #8B0020 60%, transparent);"
        >
          <p class="text-xs uppercase tracking-[0.3em] text-wedding-accent font-body mb-3">
            Programma
          </p>
          <h2
            data-letter-reveal
            class="font-display text-4xl text-wedding-text"
            style="font-weight: 600;"
          >
            Het programma
          </h2>
        </div>

        {/* Horizontal track */}
        <div class="absolute inset-0 flex items-center" style="padding-top: 140px; padding-bottom: 90px; overflow: hidden;">
          <div
            data-h-track
            class="flex gap-8 px-24 will-change-transform"
            style="width: max-content;"
          >
            {days.map((day, di) => (
              <div
                data-day-card={di}
                class={`liquid-glass rounded-2xl p-8 md:p-10 shrink-0 ${di === 0 ? 'h-card-active' : ''}`}
                style="width: min(72vw, 580px); max-height: calc(100vh - 280px); overflow-y: auto; scrollbar-width: thin; scrollbar-color: rgba(255,255,255,0.2) transparent;"
              >
                <h3
                  class="text-wedding-gold text-sm uppercase tracking-[0.15em] mb-6 pb-4"
                  style="font-weight: 500; border-bottom: 1px solid rgba(255,255,255,0.15);"
                >
                  {day.label}
                </h3>
                <div class="space-y-5">
                  {day.items.map((item) => (
                    <div class="flex gap-5 items-start">
                      {item.time && (
                        <span class="text-wedding-accent text-sm tabular-nums shrink-0 min-w-[2.5rem] pt-0.5" style="font-weight: 400;">
                          {item.time}
                        </span>
                      )}
                      <div class="flex-1 min-w-0">
                        <span class="text-wedding-text text-sm" style="font-weight: 500;">{item.title}</span>
                        {item.detail && (
                          <p class="text-wedding-muted text-xs mt-1 leading-relaxed" style="font-weight: 300;">
                            {item.detail}
                          </p>
                        )}
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>

        {/* Scroll hint */}
        <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex items-center gap-3" style="color: rgba(255,255,255,0.45); margin-top: 3rem;">
          <div class="w-8 h-px" style="background: rgba(255,255,255,0.25);" />
          <span class="text-[9px] uppercase tracking-[0.35em]">Scroll om te navigeren</span>
          <div class="w-8 h-px" style="background: rgba(255,255,255,0.25);" />
        </div>
      </div>
    </section>
  ) : (
    /* ── Vertical timeline (single day) ── */
    <section class="section-padding bg-wedding-bg">
      <div class="content-width">
        <p data-reveal class="text-xs uppercase tracking-[0.3em] text-wedding-accent font-body mb-4">
          Programma
        </p>
        <h2
          data-reveal
          data-letter-reveal
          data-reveal-delay="1"
          class="font-display text-4xl text-wedding-text mb-14"
          style="font-weight: 600;"
        >
          Het programma
        </h2>

        <div class="relative pl-6">
          <div class="absolute left-0 top-2 bottom-2 w-px bg-wedding-divider" />

          {days.map((day) => (
            <div class="mb-14 last:mb-0">
              <h3
                data-reveal
                data-reveal-delay="1"
                class="text-lg text-wedding-gold mb-8"
                style="font-weight: 500; letter-spacing: 0.05em;"
              >
                {day.label}
              </h3>

              <div class="space-y-7">
                {day.items.map((item, i) => {
                  const delay = String(Math.min(i + 1, 5));
                  return (
                    <div data-reveal data-reveal-delay={delay} class="relative">
                      <div class="absolute -left-[1.625rem] top-1.5 w-2.5 h-2.5 rounded-full bg-wedding-accent ring-2 ring-[#8B0020]" />

                      <div class="flex items-baseline gap-5">
                        {item.time && (
                          <span class="text-wedding-accent text-sm font-body tabular-nums shrink-0 min-w-[3rem]" style="font-weight: 400;">
                            {item.time}
                          </span>
                        )}
                        <div>
                          <span class="text-wedding-text font-body" style="font-weight: 500;">{item.title}</span>
                          {item.detail && (
                            <p class="text-wedding-muted text-sm mt-1 leading-relaxed" style="font-weight: 300;">
                              {item.detail}
                            </p>
                          )}
                        </div>
                      </div>
                    </div>
                  );
                })}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )
}
