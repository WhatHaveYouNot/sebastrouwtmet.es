---
interface Props {
  title: string;
  text: string;
  email: string;
}

const { title, text, email } = Astro.props;
---

<section id="acts" class="section-padding bg-wedding-bg">
  <div class="content-width">
    <div
      data-reveal
      class="liquid-glass relative px-8 py-16 md:px-14 md:py-20 text-center overflow-hidden"
    >
      <p class="relative text-xs uppercase tracking-[0.3em] text-wedding-accent font-body mb-4">Speeches & Acts</p>
      <h2
        data-reveal
        data-letter-reveal
        data-reveal-delay="1"
        class="relative font-display text-3xl md:text-4xl text-wedding-text mb-6"
        style="font-weight: 600; font-style: italic;"
      >
        {title}
      </h2>
      <p
        data-reveal
        data-reveal-delay="2"
        class="relative text-wedding-muted max-w-prose mx-auto leading-relaxed"
        style="font-weight: 300;"
      >
        {text}
      </p>

      {email && (
        <div data-reveal data-reveal-delay="3" class="relative mt-6">
          <a
            href={`mailto:${email}`}
            class="acts-email font-body"
            style="font-weight: 400;"
          >
            {email}
          </a>
        </div>
      )}

      <!-- Divider: line + dot -->
      <div class="relative flex items-center justify-center gap-4 mt-10">
        <div class="h-px flex-1" style="background: rgba(196,185,152,0.3);"></div>
        <div class="w-2 h-2 rounded-full flex-shrink-0" style="background: rgba(255,255,255,0.5);"></div>
        <div class="h-px flex-1" style="background: rgba(196,185,152,0.3);"></div>
      </div>
    </div>
  </div>
</section>

<style>
  .acts-email {
    color: #C4B998;
    font-size: 0.9rem;
    text-decoration: underline;
    text-underline-offset: 4px;
    transition: color 0.2s ease;
  }
  .acts-email:hover {
    color: #ffffff;
  }
</style>
