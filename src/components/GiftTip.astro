---
interface Props {
  title: string;
  text: string;
}

const { title, text } = Astro.props;
---

<section class="section-padding" style="background: #8B0020;">
  <div class="content-width">
    <div
      data-reveal
      class="liquid-glass relative px-8 py-16 md:px-14 md:py-20 text-center overflow-hidden"
    >
      <!-- Decorative wine background -->
      <div class="absolute inset-0 flex items-center justify-center pointer-events-none" aria-hidden="true">
        <span style="font-size: 5rem; opacity: 0.12; transform: rotate(-15deg); line-height: 1; user-select: none;">🍷</span>
      </div>

      <p class="relative text-xs uppercase tracking-[0.3em] text-wedding-accent font-body mb-4">Cadeau</p>
      <h2
        data-reveal
        data-letter-reveal
        data-reveal-delay="1"
        class="relative font-display text-3xl md:text-4xl text-wedding-text mb-6"
        style="font-weight: 600; font-style: italic;"
      >
        {title}
      </h2>
      <p
        data-reveal
        data-reveal-delay="2"
        class="relative text-wedding-muted max-w-prose mx-auto leading-relaxed"
        style="font-weight: 300;"
        set:html={text}
      />

      <!-- Floral divider -->
      <div class="relative flex items-center justify-center gap-4 mt-10">
        <div class="h-px flex-1" style="background: rgba(255,255,255,0.15);"></div>
        <img src="/images/flower-logo.png" alt="" aria-hidden="true" style="width: 18px; height: 18px; opacity: 0.35; object-fit: contain;" />
        <div class="h-px flex-1" style="background: rgba(255,255,255,0.15);"></div>
      </div>
    </div>
  </div>
</section>
